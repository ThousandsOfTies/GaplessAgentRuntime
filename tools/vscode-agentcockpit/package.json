{
  "name": "agentcockpit-terminal-bridge",
  "displayName": "AgentCockpit Terminal Bridge",
  "description": "Runs AgentCockpit terminal requests in a visible VSCode integrated terminal.",
  "version": "0.0.1",
  "publisher": "agentcockpit",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:agentcockpit.runAgpSetup"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentcockpit.runAgpSetup",
        "title": "AgentCockpit: Run AGP Setup"
      }
    ]
  }
}
